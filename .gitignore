# 비밀값
.env
.env.*
!.env.example

# 가상환경·캐시
.venv/
venv/
__pycache__/
.pytest_cache/
.ipynb_checkpoints/

# 데이터 (원본·중간·가공 모두 커밋 금지, .gitkeep만 유지)
data/raw/*
data/interim/*
data/processed/*
